---
interface CaseStudy {
  client: string;
  title: string;
  description: string;
  metric: string;
}

interface Props {
  caseStudies: CaseStudy[];
}

const { caseStudies } = Astro.props;
---

<section id="work" class="py-24 px-6 bg-bg-alt border-y border-brand-beige/50 relative z-10" aria-labelledby="work-heading">
  <div class="max-w-7xl mx-auto flex flex-col gap-16">
    
    <div class="flex flex-col items-center text-center gap-4">
      <span class="text-brand-turquoise font-semibold tracking-wider uppercase text-sm">Our Work</span>
      <h2 id="work-heading" class="text-4xl md:text-5xl font-heading font-bold text-brand-petroleum max-w-2xl">Proven impact across industries.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {caseStudies.map((study, idx) => (
        <a href="#" class="group relative flex flex-col rounded-3xl overflow-hidden bg-white border border-brand-beige hover:border-brand-turquoise/40 hover:shadow-xl transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-brand-turquoise/50" aria-label={`Read case study: ${study.title} for ${study.client}`}>
          
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 bg-[radial-gradient(ellipse_at_top_right,var(--tw-gradient-stops))] from-brand-turquoise/10 via-transparent to-transparent transition-opacity duration-500 pointer-events-none" aria-hidden="true"></div>

          <div class="p-8 flex flex-col grow relative z-10">
            <span class="text-xs font-semibold uppercase text-brand-caramel mb-3">{study.client}</span>
            <h3 class="text-2xl font-heading font-bold text-brand-petroleum mb-4 group-hover:text-brand-teal transition-colors">{study.title}</h3>
            <p class="text-brand-black/75 mb-8 grow">{study.description}</p>
            
            <div class="pt-6 border-t border-brand-beige flex items-center justify-between">
              <span class="text-sm font-medium text-brand-teal flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                {study.metric}
              </span>
              <div class="w-8 h-8 rounded-full bg-brand-turquoise/10 flex items-center justify-center text-brand-turquoise group-hover:bg-brand-turquoise group-hover:text-white group-hover:shadow-[0_0_15px_rgba(11,93,94,0.3)] transition-all" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transform group-hover:translate-x-0.5 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

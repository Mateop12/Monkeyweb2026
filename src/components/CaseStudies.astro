---
import CaseStudyCards from './react/CaseStudyCards';

interface CaseStudy {
  id?: string;
  order?: number;
  client: string;
  title: string;
  description: string;
  metric: string;
  functionalities: string[];
  images: Array<string | { src: string }>;
}

interface Props {
  caseStudies: CaseStudy[];
  whatsappPhone: string;
  /** En home: enlace “Ver más” bajo las 3 tarjetas. */
  moreProjectsHref?: string;
}

const { caseStudies, whatsappPhone, moreProjectsHref } = Astro.props;
---

<CaseStudyCards
  client:visible
  caseStudies={caseStudies}
  whatsappPhone={whatsappPhone}
  moreProjectsHref={moreProjectsHref}
/>

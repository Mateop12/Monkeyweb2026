---
import { Code2, Cloud, Cpu, Smartphone } from 'lucide-react';

interface Service {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  services: Service[];
}

const { services } = Astro.props;

// Helper to map string to React icon securely for static rendering
const iconMap = {
  Code2,
  Cloud,
  Cpu,
  Smartphone
};

---

<section id="services" class="py-24 px-6 relative z-10 bg-bg-main" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto flex flex-col gap-16">
    
    <div class="flex flex-col gap-4 max-w-3xl">
      <span class="text-brand-turquoise font-semibold tracking-wider uppercase text-sm">Capabilities</span>
      <h2 id="services-heading" class="text-4xl md:text-5xl font-heading font-bold text-brand-petroleum">Full-Stack Solutions for Modern Businesses.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service, index) => {
        const IconComponent = iconMap[service.icon as keyof typeof iconMap] || Code2;

        return (
          <div 
            class="group p-8 rounded-3xl bg-white border border-brand-beige hover:border-brand-turquoise/30 hover:bg-bg-alt hover:shadow-xl transition-all duration-500 ease-out hover:-translate-y-2 relative overflow-hidden"
            style={`animation-delay: ${index * 150}ms`}
            tabindex="0"
          >
            {/* Background Hover Glow */}
            <div class="absolute inset-0 bg-linear-to-br from-brand-turquoise/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-out" aria-hidden="true"></div>
            
            <div class="relative z-10 flex flex-col gap-6">
              <div class="w-14 h-14 rounded-2xl bg-brand-turquoise/10 border border-brand-turquoise/20 flex items-center justify-center text-brand-turquoise group-hover:scale-110 group-hover:text-brand-teal transition-all duration-500">
                <IconComponent size={28} strokeWidth={1.5} aria-hidden="true" />
              </div>
              
              <div class="flex flex-col gap-3">
                <h3 class="text-xl font-heading font-bold text-brand-petroleum group-hover:text-brand-teal transition-colors">{service.title}</h3>
                <p class="text-brand-black/70 leading-relaxed text-sm">
                  {service.description}
                </p>
              </div>
            </div>
            
            <!-- decorative corner border -->
            <div class="absolute bottom-0 right-0 w-24 h-24 bg-linear-to-tl from-brand-beige/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none rounded-br-3xl" aria-hidden="true"></div>
          </div>
        );
      })}
    </div>

  </div>
</section>

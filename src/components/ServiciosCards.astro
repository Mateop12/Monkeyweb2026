---
import serviciosPage from '../content/landing/servicios.json';

const ICON_SLUGS = new Set(['code', 'puzzle', 'layers', 'trend']);

type IconSlug = 'code' | 'puzzle' | 'layers' | 'trend';

function normIcon(raw: unknown): IconSlug {
  const s = String(raw ?? 'code').toLowerCase().trim();
  if (ICON_SLUGS.has(s)) return s as IconSlug;
  return 'code';
}

function cardImageUrl(card: Record<string, unknown>): string | null {
  const v = card.image;
  if (typeof v === 'string' && v.trim()) return v.trim();
  return null;
}

interface CardView {
  title: string;
  description: string;
  href: string;
  ariaLabel: string;
  icon: IconSlug;
  imgUrl: string | null;
}

function toCardView(raw: unknown): CardView | null {
  if (!raw || typeof raw !== 'object') return null;
  const card = raw as Record<string, unknown>;
  const title = String(card.title ?? '');
  if (!title) return null;
  return {
    title,
    description: String(card.description ?? ''),
    href: String(card.href ?? '/contacto'),
    ariaLabel: String(card.ariaLabel ?? `Más información: ${title}`),
    icon: normIcon(card.icon),
    imgUrl: cardImageUrl(card),
  };
}

const eyebrow = serviciosPage.eyebrow ?? 'Lo que ofrecemos';
const heading = serviciosPage.heading ?? '';
const intro = serviciosPage.intro ?? '';
const rawCards = Array.isArray(serviciosPage.cards) ? serviciosPage.cards : [];
const cardsList: CardView[] = rawCards.map(toCardView).filter((c): c is CardView => c !== null);
---

<section
  class="relative z-10 overflow-hidden bg-bg-main px-6 py-20 sm:py-24"
  aria-labelledby="servicios-cards-heading"
>
  <div
    class="pointer-events-none absolute -top-32 right-0 h-[500px] w-[500px] rounded-full bg-brand-turquoise/5 blur-[120px]"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute bottom-0 left-0 h-64 w-64 rounded-full bg-brand-caramel/5 blur-[100px]"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <div class="mb-12 max-w-3xl text-left sm:mb-14 md:mb-16">
      <span class="font-heading text-sm font-semibold uppercase tracking-[0.2em] text-brand-turquoise">
        {eyebrow}
      </span>
      <h2
        id="servicios-cards-heading"
        class="font-heading mt-3 text-3xl font-bold tracking-tight text-brand-petroleum sm:text-4xl md:text-5xl md:leading-tight"
      >
        {heading}
      </h2>
      {
        intro ? (
          <p class="mt-4 max-w-2xl text-sm leading-relaxed text-brand-black/70 sm:text-base">
            {intro}
          </p>
        ) : null
      }
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        cardsList.map((card) => (
          <article class="group relative flex flex-col overflow-hidden rounded-3xl border border-brand-beige bg-[var(--bg-card)] p-8 transition-all duration-500 hover:-translate-y-2 hover:border-brand-turquoise/30 hover:bg-[var(--bg-card-hover)]">
            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand-turquoise/5 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
              aria-hidden="true"
            />
            <div class="relative z-10 flex min-h-0 flex-1 flex-col gap-6">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-brand-turquoise/20 bg-brand-turquoise/10 text-brand-turquoise transition-transform duration-500 group-hover:scale-110">
                {card.imgUrl ? (
                  <img
                    src={card.imgUrl}
                    alt={`Ilustración del servicio «${card.title}» — Monkeymind, desarrollo de software`}
                    title={`Servicio: ${card.title}`}
                    class="h-full w-full object-contain p-1.5"
                    loading="lazy"
                    decoding="async"
                  />
                ) : card.icon === 'code' ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-7 w-7"
                    aria-hidden="true"
                  >
                    <path d="m18 16 4-4-4-4" />
                    <path d="m6 8-4 4 4 4" />
                    <path d="m14.5 4-5 16" />
                  </svg>
                ) : card.icon === 'puzzle' ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-7 w-7"
                    aria-hidden="true"
                  >
                    <path d="M15.39 4.39a1 1 0 0 0 1.68-.474 2.5 2.5 0 1 1 3.014 3.015 1 1 0 0 0-.474 1.68l1.683 1.682a2.414 2.414 0 0 1 0 3.414L19.61 15.39a1 1 0 0 1-1.68-.474 2.5 2.5 0 1 0-3.014 3.015 1 1 0 0 1 .474 1.68l-1.683 1.682a2.414 2.414 0 0 1-3.414 0L8.61 19.61a1 1 0 0 0-1.68.474 2.5 2.5 0 1 1-3.014-3.015 1 1 0 0 0 .474-1.68l-1.683-1.682a2.414 2.414 0 0 1 0-3.414L4.39 8.61a1 1 0 0 1 1.68.474 2.5 2.5 0 1 0 3.014-3.015 1 1 0 0 1-.474-1.68l1.683-1.682a2.414 2.414 0 0 1 3.414 0z" />
                  </svg>
                ) : card.icon === 'layers' ? (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-7 w-7"
                    aria-hidden="true"
                  >
                    <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z" />
                    <path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12" />
                    <path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17" />
                  </svg>
                ) : (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="h-7 w-7"
                    aria-hidden="true"
                  >
                    <path d="M16 7h6v6" />
                    <path d="m22 7-8.5 8.5-5-5L2 17" />
                  </svg>
                )}
              </div>
              <div class="flex min-h-0 flex-1 flex-col gap-3">
                <h3 class="font-heading text-xl font-bold text-brand-petroleum transition-colors group-hover:text-brand-teal">
                  {card.title}
                </h3>
                <p class="flex-1 text-sm leading-relaxed text-brand-black/70 sm:text-[0.9375rem]">
                  {card.description}
                </p>
              </div>
              <a
                href={card.href}
                class="mt-auto inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-brand-turquoise transition-colors hover:text-brand-teal"
                aria-label={card.ariaLabel}
              >
                VER MÁS
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4 shrink-0 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                  aria-hidden="true"
                >
                  <path d="M7 7h10v10" />
                  <path d="M7 17 17 7" />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

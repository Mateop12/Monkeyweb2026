---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Página no encontrada | Monkeymind"
  description="La página que buscas no existe o fue movida. Vuelve al inicio o explora nuestros servicios."
  noindex={true}
  image="/monkeymind.webp"
>
  <Navbar />
  <main class="mx-auto flex max-w-lg flex-col items-center px-6 pb-24 pt-28 text-center sm:pt-32">
    <p class="text-brand-turquoise mb-2 text-sm font-semibold uppercase tracking-wider">Error 404</p>
    <h1 class="font-heading text-brand-petroleum mb-4 text-3xl font-extrabold sm:text-4xl">Esta página no existe</h1>
    <p class="text-brand-black/70 mb-10 text-base leading-relaxed">
      Puede que el enlace esté desactualizado o que hayas escrito mal la URL.
    </p>
    <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-full bg-brand-petroleum px-8 py-3 text-sm font-semibold text-white transition-all hover:-translate-y-0.5 hover:bg-brand-teal"
      >
        Ir al inicio
      </a>
      <a
        href="/contacto"
        class="inline-flex items-center justify-center rounded-full border border-brand-beige px-8 py-3 text-sm font-semibold text-brand-petroleum transition-colors hover:border-brand-turquoise/40 hover:text-brand-turquoise"
      >
        Contacto
      </a>
    </div>
  </main>
  <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

import nosotrosData from '../content/landing/nosotros.json';
---

<Layout title={`${nosotrosData.title} | Innovate Software`}>
  <Navbar />
  
  <main class="flex flex-col pt-32 pb-24 px-6 max-w-4xl mx-auto min-h-[80vh]">
    <div class="flex flex-col gap-12 animate-[fade-in-up_0.8s_ease-out_forwards]">
      <h1 class="text-5xl md:text-6xl font-heading font-extrabold text-brand-petroleum">
        {nosotrosData.title}
      </h1>

      <div class="flex flex-col gap-8 bg-white p-10 rounded-3xl border border-brand-beige shadow-xl/10">
        <div>
          <h2 class="text-xl font-heading font-bold text-brand-turquoise bg-brand-turquoise/10 inline-block px-3 py-1 rounded-full mb-4">Misión</h2>
          <p class="text-brand-black/80 leading-relaxed text-lg">
            {nosotrosData.mission}
          </p>
        </div>
        
        <div class="h-px bg-brand-beige/50 w-full"></div>

        <div>
          <h2 class="text-xl font-heading font-bold text-brand-teal bg-brand-turquoise/10 inline-block px-3 py-1 rounded-full mb-4">Visión</h2>
          <p class="text-brand-black/80 leading-relaxed text-lg">
            {nosotrosData.vision}
          </p>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

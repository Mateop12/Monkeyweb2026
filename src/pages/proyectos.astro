---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Testimonials from '../components/react/Testimonials.tsx';
import Footer from '../components/Footer.astro';

import homeData from '../content/landing/home.json';

const pageSchema = {
  '@type': 'CollectionPage',
  name: 'Casos de éxito | Monkeymind',
  description:
    'Casos de éxito y proyectos de desarrollo de software, plataformas web y aplicaciones a medida realizados por Monkeymind.',
};
---

<Layout
  title="Monkeymind | Casos de Éxito y Proyectos"
  description="Casos de éxito: proyectos de desarrollo web, plataformas escalables y software a medida. Testimonios de clientes y resultados medibles."
  keywords="casos éxito desarrollo software, proyectos web Medellín, portafolio software Colombia, testimonios Monkeymind"
  image="/ideasmonkeymind.webp"
  pageSchema={pageSchema}
>
  <Navbar />
  
  <main class="flex flex-col pt-20">
    <div class="px-6 py-16 text-center max-w-3xl mx-auto">
      <h1 class="text-5xl md:text-6xl font-heading font-extrabold text-brand-petroleum mb-6 animate-[fade-in-up_0.8s_ease-out_forwards]">
        Casos de Éxito
      </h1>
      <p class="text-brand-black/70 text-lg animate-[fade-in-up_0.8s_ease-out_0.2s_forwards] opacity-0">
        Descubre cómo hemos ayudado a empresas líderes a transformar sus operaciones mediante arquitectura de software de alta disponibilidad y diseño impecable.
      </p>
    </div>

    <!-- Reuse the component to render the cards inside the page body -->
    <CaseStudies caseStudies={homeData.caseStudies} />

    <!-- Testimonials Section -->
    <Testimonials client:visible testimonials={homeData.testimonials} />
  </main>

  <Footer />
</Layout>
